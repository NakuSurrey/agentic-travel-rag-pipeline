# === LLM Provider (Groq - free tier) ===
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# === Pinecone ===
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=travel-rag

# === Embedding Model (uses sentence-transformers locally — free) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === FastAPI ===
HOST=0.0.0.0
PORT=8000

# === API Authentication ===
APP_API_KEY=your_api_key_here

# === Reverse Proxy (optional) ===
# set this when running behind a reverse proxy at a subpath (e.g. /travel-api)
# leave empty or remove for local development
ROOT_PATH=
